<% frame_id = "product_#{html_id}_upload_frame" %>
<%= turbo_frame_tag frame_id do %>
  <% if reload %>
    <div id="<%= "#{html_id}filtering_tests_table_poller" %>"
      data-controller="turbo-stream-poller"
      data-turbo-temporary
      data-turbo-stream-poller-url-value="<%= product_page_url %>"
      data-turbo-stream-poller-params-value="<%= { partial: "cvu_multi_display", html_id: html_id, reload: reload }.to_json %>"
      data-turbo-stream-poller-interval-value="15000"></div>
  <% end %>
<% end %>
