<% if params[:partial] == 'checklist_measures' %>
  <% if @product_test.tasks[0].most_recent_execution.incomplete? %>
    <%= turbo_stream.replace "display_checklist_measures" do %>
      <%= render "/checklist_tests/checklist_measures", :product_test => @product_test, :product => @product_test.product, :measures => @measures %>
    <% end %>
   <% else %>
    <%= turbo_stream.replace "display_checklist_measures" do %>
      <%= render "/checklist_tests/checklist_measures", :product_test => @product_test, :product => @product_test.product, :measures => @measures %>
    <% end %>
    <%= turbo_stream.remove "checklist_measures_poller" %>
   <% end %>
<% elsif params[:partial] == 'checklist_status_display' %>
  <% if @product_test.tasks[0].most_recent_execution.incomplete? %>
    <%= turbo_stream.replace "display_checklist_status" do %>
      <%= render "/application/checklist_status_display", :product_test => @product_test, :product => @product_test.product %>
    <% end %>
   <% else %>
    <%= turbo_stream.replace "display_checklist_status" do %>
      <%= render "/application/checklist_status_display", :product_test => @product_test, :product => @product_test.product %>
    <% end %>
    <%= turbo_stream.remove "checklist_status_display_poller" %>
   <% end %>
<% elsif params[:partial] == 'checklist_execution_results' %>
  <% if params[:task_id] %>
    <% if @task.most_recent_execution && @task.most_recent_execution.executions_pending? %>
      <%= turbo_stream.replace "display_checklist_execution_results" do %>
        <%= render "/application/checklist_execution_results", :task => @task %>
      <% end %>
    <% else %>
      <%= turbo_stream.replace "display_checklist_execution_results" do %>
        <%= render "/application/checklist_execution_results", :task => @task %>
      <% end %>
      <%= turbo_stream.remove "checklist_execution_results_poller" %>
    <% end %>
  <% end %>
<% end %>
