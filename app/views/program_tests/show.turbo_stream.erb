<% if params[:partial] == 'program_fields' %>
  <% if @product_test.tasks[0].most_recent_execution.incomplete? %>
    <%= turbo_stream.replace "display_program_fields" do %>
      <%= render "/program_tests/program_fields", :product_test => @product_test, :product => @product_test.product, :task => @task %>
    <% end %>
   <% else %>
      <%= turbo_stream.remove "program_fields_poller" %>
   <% end %>
<% elsif params[:partial] == 'checklist_status_display' %>
  <% if @product_test.tasks[0].most_recent_execution.incomplete? %>
   setTimeout(function(){
      $('#display_checklist_status').html("<%= escape_javascript render 'checklist_status_display', :product_test => @product_test, :product => @product_test.product %>");
    }, 2000);
   <% else %>
      $('#display_checklist_status').html("<%= escape_javascript render 'checklist_status_display', :product_test => @product_test, :product => @product_test.product %>");
   <% end %>
<% elsif params[:partial] == 'checklist_execution_results' %>
  <% if params[:task_id] %>
    <% if @task.most_recent_execution && @task.most_recent_execution.executions_pending? %>
      setTimeout(function(){
        $('#display_checklist_execution_results').html("<%= escape_javascript render 'checklist_execution_results', :task => @task %>");
      }, 2000);
    <% else %>
      $('#display_checklist_execution_results').html("<%= escape_javascript render 'checklist_execution_results', :task => @task %>");
    <% end %>
  <% end %>
<% end %>
